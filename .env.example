DISCORD_TOKEN=coloque_o_token_do_bot
# Opcional: se preenchido, tem prioridade sobre DISCORD_TOKEN.
DISCORD_BOT_TOKEN=
CLIENT_ID=id_da_aplicacao
# Opcional: usado por scripts de publicacao/sync de um servidor especifico.
GUILD_ID=
# Opcional: lista de servidores para limpar comandos locais antigos, separados por virgula.
GUILD_COMMAND_CLEAR_IDS=

# Opcional: cargo que pode administrar produtos e pedidos.
# Se vazio, usuarios com Permissao Gerenciar Servidor tambem podem administrar.
ADMIN_ROLE_ID=

# Opcional: canal onde o bot envia logs de vendas.
SALES_LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=
OWNER_ROLE_ID=
OWNER_USER_ID=
FUTURE_CLIENT_ROLE_ID=
UNVERIFIED_ROLE_ID=
CONTRACT_LOG_CHANNEL_ID=
CONTRACT_PDF_LOG_CHANNEL_ID=
BAD_WORDS=palavrao,spam

# Limpeza segura de mensagens com /clean.
CLEAN_MAX_MESSAGES=100
CLEAN_SCAN_LIMIT=200
CLEAN_CONFIRM_TTL_MS=300000
CLEAN_LOG_CHANNEL_ID=
CLEAN_SKIP_PINNED=true

# Paineis de venda.
# Se vazio, o setup usa planos-e-precos para Mensal e comprar-agora para Vitalicio.
MONTHLY_PLAN_CHANNEL_ID=
LIFETIME_PLAN_CHANNEL_ID=
# Compatibilidade com versoes antigas.
CANAL_ID=
PLAN_PANEL_CHANNEL_ID=
BUY_NOW_CHANNEL_ID=

# MongoDB.
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=orvitek
MONGODB_ORDERS_COLLECTION=pedidos
MONGODB_STORE_COLLECTION=bot_store
MONGODB_HOSTING_EVENTS_COLLECTION=hosting_shutdown_events
MONGODB_HOSTING_PERMISSIONS_COLLECTION=hosting_registration_permissions
MONGODB_REQUIRED=true

# PagBank/PagSeguro Pix.
# Use sandbox para testes e production quando a integração estiver homologada.
PAGBANK_ENV=sandbox
PAGBANK_TOKEN=
PAGBANK_URL=https://sandbox.api.pagseguro.com
WEBHOOK_URL=https://seusite.com/webhook/pagbank
PORT=3000
PAGBANK_NOTIFICATION_URL=https://seusite.com/webhook/pagbank
PAGBANK_QR_EXPIRATION_MINUTES=1440

# Gmail para comprovantes.
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=sua_app_password_aqui

DELIVERED_PROJECT_CATEGORY_ID=1506262092565450963

SERVER_NAME=meu-servidor
BOT_VERSION=v1.0.0

# Dashboard/API do sistema.
DASHBOARD_ENABLED=false
DASHBOARD_URL=
DASHBOARD_BOT_ID=
BOT_DASHBOARD_TOKEN=

# Bot Orvitek Hospedagem.
# Recebe POST quando a hospedagem deve ser desligada por atraso.
ORVITEK_HOSTING_BOT_ENABLED=false
ORVITEK_API_KEY=troque_esta_chave
HOSTING_API_URL=https://hospedagem.seudominio.com
HOSTING_BOT_API_URL=
ORVITEK_HOSTING_BOT_URL=https://hospedagem.seudominio.com/api/orvitek/desligar
ORVITEK_HOSTING_BOT_RESTORE_URL=https://hospedagem.seudominio.com/api/orvitek/religar
ORVITEK_HOSTING_BOT_TOKEN=troque_este_token
ORVITEK_HOSTING_BOT_TIMEOUT_MS=10000
ORVITEK_HOSTING_BOT_DEBUG=false
