DISCORD_TOKEN=coloque_o_token_do_bot
CLIENT_ID=id_da_aplicacao
GUILD_ID=id_do_servidor

# Opcional: cargo que pode administrar produtos e pedidos.
# Se vazio, usuarios com Permissao Gerenciar Servidor tambem podem administrar.
ADMIN_ROLE_ID=

# Opcional: canal onde o bot envia logs de vendas.
SALES_LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=
OWNER_ROLE_ID=
FUTURE_CLIENT_ROLE_ID=
UNVERIFIED_ROLE_ID=
CONTRACT_LOG_CHANNEL_ID=
BAD_WORDS=palavrao,spam

# PagBank/PagSeguro Pix.
# Use sandbox para testes e production quando a integração estiver homologada.
PAGBANK_ENV=sandbox
PAGBANK_TOKEN=
PAGBANK_URL=https://sandbox.api.pagseguro.com
WEBHOOK_URL=https://seusite.com/webhook/pagbank
PORT=3000
PAGBANK_NOTIFICATION_URL=
PAGBANK_QR_EXPIRATION_MINUTES=1440

# Gmail para comprovantes.
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=sua_app_password_aqui

# Discord para comprovantes por DM.
# Se vazio, o sistema usa DISCORD_TOKEN como fallback.
DISCORD_BOT_TOKEN=
DELIVERED_PROJECT_CATEGORY_ID=1506262092565450963

# Dashboard em tempo real.
DASHBOARD_URL=http://127.0.0.1:3333
DASHBOARD_BOT_ID=b1
# Usado pelo bot para solicitar codigo em /api/auth/panel/issue.
BOT_DASHBOARD_TOKEN=1505184193766752386
SERVER_NAME=meu-servidor
BOT_VERSION=v1.0.0
